# Copy this file to .env and fill in real values before first run.
# Never commit your real .env file.

# Port the app listens on inside the container
PORT=3000

# Used to sign login session tokens (JWT). Generate with:
#   openssl rand -hex 32
JWT_SECRET=change_this_to_a_long_random_string

# Used to encrypt SSH credentials stored in the database (AES-256-GCM).
# Must be exactly 32 bytes when hex-decoded. Generate with:
#   openssl rand -hex 32
CREDENTIAL_ENC_KEY=change_this_to_a_64_char_hex_string

# Bootstrap admin account created automatically on first launch
# (only if no admin user exists yet).
ADMIN_EMAIL=admin@kyberbox.app
ADMIN_PASSWORD=change_this_password

# Public site name shown in the portal (can also be changed later from Admin -> Settings)
SITE_NAME=KyberBOX

# Only needed if you have more than one reverse proxy hop in front of this
# container (e.g. Authentik + another proxy). Defaults to 1 if not set,
# which is correct for the typical single-reverse-proxy setup.
# TRUST_PROXY=1

# Note: SMTP (mail) settings and the public site URL used in email links are
# configured from inside the app under Admin -> Settings after you log in,
# not here. Nothing will be emailed until you set that up.
