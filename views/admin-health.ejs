<!DOCTYPE html>
<html lang="en">
<head>
    <% pageTitle = 'Health' %>
    <%- include('partials/head') %>
</head>
<body class="antialiased overflow-x-hidden">
    <%- include('partials/nav') %>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-10 pb-24">
        <h1 class="text-2xl sm:text-3xl font-extrabold mb-2">Server Health</h1>
        <p class="text-slate-400 text-sm mb-8">A live view of any container in your compose stack, independent of any single plan.</p>

        <% if (!sshConfigured) { %>
            <div class="mb-8 px-4 sm:px-5 py-4 rounded-xl bg-amber-500/10 border border-amber-500/30 text-amber-400 text-sm flex items-center justify-between flex-wrap gap-3">
                <span><i class="fas fa-triangle-exclamation mr-2"></i>No server access configured yet for this page.</span>
                <a href="/admin/settings" class="btn-amber px-4 py-2 rounded-lg text-xs whitespace-nowrap">Set Up in Settings</a>
            </div>
        <% } %>

        <!-- Add container -->
        <div class="glass rounded-2xl sm:rounded-3xl p-5 sm:p-8 mb-8">
            <h2 class="text-lg font-bold text-white mb-4"><i class="fas fa-plus mr-2 text-sky-400"></i>Add a Container to Monitor</h2>
            <form method="POST" action="/admin/health/containers" enctype="multipart/form-data" class="grid sm:grid-cols-4 gap-3">
                <input type="text" name="label" required class="input" placeholder="Display label (e.g. Plex Server)">
                <input type="text" name="container_name" required class="input" placeholder="Exact container name (e.g. plex)">
                <input type="file" name="logo" accept="image/png,image/jpeg,image/webp,image/svg+xml" class="input text-xs sm:col-span-1">
                <button type="submit" class="btn-primary py-3 rounded-xl text-sm">Add Container</button>
            </form>
            <p class="text-slate-500 text-xs mt-2">Logo is optional - square images work best. You can add or change it later too.</p>
        </div>

        <!-- Containers -->
        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-bold mb-4">Containers (<%= containers.length %>)</h2>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-6" id="healthContainerList">
            <% containers.forEach(function(c, index) { %>
                <div class="glass rounded-3xl p-6 flex flex-col items-center text-center gap-3" data-container-row data-container-id="<%= c.id %>">
                    <div class="w-16 h-16 rounded-2xl bg-slate-900/60 border border-white/10 flex items-center justify-center overflow-hidden flex-shrink-0">
                        <% if (c.logo_path) { %>
                            <img src="<%= c.logo_path %>" alt="<%= c.label %>" class="w-full h-full object-contain p-2">
                        <% } else { %>
                            <i class="fas fa-cube text-slate-600 text-2xl"></i>
                        <% } %>
                    </div>

                    <div>
                        <p class="font-semibold text-white text-sm"><%= c.label %></p>
                        <p class="text-slate-500 text-xs font-mono"><%= c.container_name %></p>
                    </div>

                    <span class="badge badge-suspended" data-status-pill><i class="fas fa-circle-notch fa-spin"></i> checking</span>

                    <div class="flex items-center gap-2 flex-wrap justify-center">
                        <button class="btn-outline px-3 py-2 rounded-lg text-xs" data-health-btn data-health-action="stop" data-health-id="<%= c.id %>" data-health-label="<%= c.label %>">
                            <i class="fas fa-stop mr-1"></i>Stop
                        </button>
                        <button class="btn-amber px-3 py-2 rounded-lg text-xs" data-health-btn data-health-action="restart" data-health-id="<%= c.id %>" data-health-label="<%= c.label %>">
                            <i class="fas fa-rotate mr-1"></i>Restart
                        </button>
                    </div>

                    <div class="flex items-center gap-1 flex-wrap justify-center pt-2 border-t border-white/5 w-full mt-1">
                        <form method="POST" action="/admin/health/containers/<%= c.id %>/move">
                            <input type="hidden" name="direction" value="up">
                            <button class="w-7 h-7 rounded-lg text-slate-400 hover:text-white hover:bg-white/5 text-xs" title="Move left/up" <%= index === 0 ? 'disabled style=opacity:0.3' : '' %>>
                                <i class="fas fa-arrow-up"></i>
                            </button>
                        </form>
                        <form method="POST" action="/admin/health/containers/<%= c.id %>/move">
                            <input type="hidden" name="direction" value="down">
                            <button class="w-7 h-7 rounded-lg text-slate-400 hover:text-white hover:bg-white/5 text-xs" title="Move right/down" <%= index === containers.length - 1 ? 'disabled style=opacity:0.3' : '' %>>
                                <i class="fas fa-arrow-down"></i>
                            </button>
                        </form>
                        <button type="button" class="w-7 h-7 rounded-lg text-slate-400 hover:text-white hover:bg-white/5 text-xs" title="Change logo" onclick="document.getElementById('logoForm-<%= c.id %>').classList.toggle('hidden')">
                            <i class="fas fa-image"></i>
                        </button>
                        <form method="POST" action="/admin/health/containers/<%= c.id %>/delete" onsubmit="return confirm('Stop monitoring this container?');">
                            <button class="w-7 h-7 rounded-lg text-red-400 hover:text-red-300 hover:bg-red-500/10 text-xs" title="Remove">
                                <i class="fas fa-trash"></i>
                            </button>
                        </form>
                    </div>

                    <form id="logoForm-<%= c.id %>" method="POST" action="/admin/health/containers/<%= c.id %>/logo" enctype="multipart/form-data" class="hidden w-full flex gap-2 mt-1">
                        <input type="file" name="logo" accept="image/png,image/jpeg,image/webp,image/svg+xml" class="input text-xs flex-1">
                        <button type="submit" class="btn-primary px-3 py-2 rounded-lg text-xs whitespace-nowrap">Save</button>
                    </form>
                </div>
            <% }); %>
            <% if (containers.length === 0) { %>
                <p class="text-slate-500 text-sm">No containers added yet.</p>
            <% } %>
        </div>
        <div id="healthActionResult" class="hidden text-sm rounded-xl p-4 mb-10"></div>

        <!-- Recent actions -->
        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-bold mb-4">Recent Stop/Restart Requests</h2>
        <div class="glass rounded-2xl overflow-x-auto">
            <% if (recentLog.length === 0) { %>
                <p class="text-slate-500 text-sm p-6">No requests yet.</p>
            <% } else { %>
                <table class="kb-table min-w-[560px]">
                    <thead><tr><th>Admin</th><th>Container</th><th>Action</th><th>Time (UK)</th><th>Result</th></tr></thead>
                    <tbody>
                        <% recentLog.forEach(function(l) { %>
                            <tr>
                                <td class="text-slate-300"><%= l.admin_name %></td>
                                <td class="text-slate-400 font-mono"><%= l.container_name %></td>
                                <td class="text-slate-400 capitalize"><%= l.action %></td>
                                <td class="text-slate-500 text-xs"><%= formatUK(l.requested_at) %></td>
                                <td><span class="badge <%= l.success ? 'badge-active' : 'badge-expired' %>"><%= l.success ? 'Success' : 'Failed' %></span></td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </main>

    <script>
        const STATUS_MAP = {
            up: ['badge-active', 'fa-circle-check', 'Online'],
            starting: ['badge-suspended', 'fa-circle-notch fa-spin', 'Starting'],
            unhealthy: ['badge-expired', 'fa-triangle-exclamation', 'Unhealthy'],
            down: ['badge-expired', 'fa-circle-xmark', 'Offline'],
            unknown: ['badge-closed', 'fa-question', 'Unknown'],
        };

        async function refreshHealth() {
            try {
                const res = await fetch('/admin/health/status');
                const data = await res.json();
                if (!data.ok) return;
                data.containers.forEach(function(c) {
                    const row = document.querySelector('[data-container-id="' + c.id + '"] [data-status-pill]');
                    if (!row) return;
                    const chosen = STATUS_MAP[c.status] || STATUS_MAP.unknown;
                    row.className = 'badge ' + chosen[0];
                    row.innerHTML = '<i class="fas ' + chosen[1] + '"></i> ' + chosen[2];
                });
            } catch (e) {
                // leave "checking" state as-is
            }
        }
        refreshHealth();

        document.querySelectorAll('[data-health-btn]').forEach(function(btn) {
            btn.addEventListener('click', async function() {
                const action = btn.getAttribute('data-health-action');
                const label = btn.getAttribute('data-health-label');
                const id = btn.getAttribute('data-health-id');
                if (!confirm((action === 'stop' ? 'Stop' : 'Restart') + ' "' + label + '" now?')) return;

                const resultBox = document.getElementById('healthActionResult');
                const originalHtml = btn.innerHTML;
                btn.disabled = true;
                btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

                try {
                    const res = await fetch('/admin/health/containers/' + id + '/' + action, { method: 'POST' });
                    const data = await res.json();
                    resultBox.classList.remove('hidden');
                    resultBox.className = 'text-sm rounded-xl p-4 mb-10 ' + (data.ok
                        ? 'bg-emerald-500/10 border border-emerald-500/30 text-emerald-400'
                        : 'bg-red-500/10 border border-red-500/30 text-red-400');
                    resultBox.textContent = data.message;
                    refreshHealth();
                } catch (e) {
                    resultBox.classList.remove('hidden');
                    resultBox.className = 'text-sm rounded-xl p-4 mb-10 bg-red-500/10 border border-red-500/30 text-red-400';
                    resultBox.textContent = 'Something went wrong sending that request.';
                } finally {
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                }
            });
        });
    </script>
</body>
</html>
