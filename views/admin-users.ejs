<!DOCTYPE html>
<html lang="en">
<head>
    <% pageTitle = 'Manage Users' %>
    <%- include('partials/head') %>
</head>
<body class="antialiased overflow-x-hidden">
    <%- include('partials/nav') %>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-10 pb-24">
        <h1 class="text-2xl sm:text-3xl font-extrabold mb-8">Manage Users</h1>

        <% if (newUser) { %>
            <div class="glass rounded-2xl p-6 mb-8 border border-emerald-500/30">
                <p class="text-emerald-400 font-bold mb-2"><i class="fas fa-circle-check mr-2"></i>Account ready for <%= newUser.name %></p>
                <p class="text-slate-300 text-sm">Email: <span class="font-mono break-all"><%= newUser.email %></span></p>
                <p class="text-slate-300 text-sm mb-2">Temporary password: <span class="font-mono bg-slate-900/60 px-2 py-1 rounded"><%= newUser.tempPassword %></span></p>
                <% if (newUser.emailSent) { %>
                    <p class="text-emerald-400 text-xs"><i class="fas fa-envelope-circle-check mr-1"></i>This was also emailed to the client automatically.</p>
                <% } else { %>
                    <p class="text-amber-400 text-xs"><i class="fas fa-triangle-exclamation mr-1"></i>Email not sent (<%= newUser.emailReason || 'mail not configured' %>) — share these details with the client yourself, or set up SMTP under <a href="/admin/settings" class="underline">Settings</a>.</p>
                <% } %>
                <p class="text-slate-500 text-xs mt-2">Shown only once — copy it now if needed.</p>
            </div>
        <% } %>

        <% if (plans.length === 0) { %>
            <div class="mb-8 px-4 sm:px-5 py-4 rounded-xl bg-amber-500/10 border border-amber-500/30 text-amber-400 text-sm flex items-center justify-between flex-wrap gap-3">
                <span><i class="fas fa-layer-group mr-2"></i>You haven't created any Plans yet — create one first so you can assign new clients to it.</span>
                <a href="/admin/plans" class="btn-amber px-4 py-2 rounded-lg text-xs whitespace-nowrap">Create a Plan</a>
            </div>
        <% } %>

        <!-- Payment Methods -->
        <div class="glass rounded-3xl p-6 sm:p-8 mb-8">
            <h2 class="text-lg font-bold text-white mb-4"><i class="fas fa-credit-card mr-2 text-sky-400"></i>Payment Methods</h2>
            <p class="text-slate-400 text-sm mb-4">Names only for now — assign one to each client below.</p>
            <div class="flex flex-wrap gap-2 mb-4">
                <% paymentMethods.forEach(function(pm) { %>
                    <form method="POST" action="/admin/payment-methods/<%= pm.id %>/delete" onsubmit="return confirm('Delete this payment method? Any clients using it will be unassigned.');" class="flex items-center gap-2 bg-slate-900/40 rounded-lg px-3 py-2 text-xs text-slate-300">
                        <span><%= pm.name %></span>
                        <button class="text-red-400 hover:text-red-300"><i class="fas fa-trash"></i></button>
                    </form>
                <% }); %>
                <% if (paymentMethods.length === 0) { %>
                    <p class="text-slate-500 text-sm">No payment methods added yet.</p>
                <% } %>
            </div>
            <form method="POST" action="/admin/payment-methods" class="flex flex-col sm:flex-row gap-3">
                <input type="text" name="name" required class="input" placeholder="Payment method name (e.g. Bank Transfer, PayPal)">
                <button type="submit" class="btn-primary py-3 rounded-xl text-sm whitespace-nowrap">Add Method</button>
            </form>
        </div>

        <!-- Invite form -->
        <div class="glass rounded-3xl p-6 sm:p-8 mb-12">
            <h2 class="text-lg font-bold text-white mb-4"><i class="fas fa-user-plus mr-2 text-sky-400"></i>Invite a New Client</h2>
            <form method="POST" action="/admin/users/invite" class="grid sm:grid-cols-2 gap-4">
                <input type="text" name="name" required class="input" placeholder="Full name">
                <input type="email" name="email" required class="input" placeholder="Email address">
                <select name="plan_id" class="input sm:col-span-2">
                    <option value="">No plan yet (assign later)</option>
                    <% plans.forEach(function(p) { %>
                        <option value="<%= p.id %>"><%= p.name %> (<%= p.service %>)</option>
                    <% }); %>
                </select>
                <button type="submit" class="btn-primary py-3 rounded-xl text-sm sm:col-span-2">
                    <i class="fas fa-paper-plane mr-2"></i>Create Account
                </button>
            </form>
        </div>

        <!-- Users list -->
        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-bold mb-4">All Clients (<%= users.length %>)</h2>
        <div class="space-y-4">
            <% users.forEach(function(u) { %>
                <div class="glass rounded-2xl p-5 sm:p-6">
                    <div class="flex flex-wrap items-center justify-between gap-3 mb-3">
                        <div class="min-w-0">
                            <p class="font-bold text-white truncate"><%= u.name %></p>
                            <p class="text-slate-500 text-xs truncate"><%= u.email %></p>
                        </div>
                        <div class="flex flex-wrap gap-2">
                            <% (subsByUser[u.id] || []).forEach(function(s) { %>
                                <span class="badge badge-<%= s.status %>"><%= s.plan_display_name || s.plan_name %>: <%= s.status %></span>
                            <% }); %>
                            <% if (u.payment_method_id) { %>
                                <% const pm = paymentMethods.find(function(p) { return p.id === u.payment_method_id; }); %>
                                <span class="badge badge-answered"><i class="fas fa-credit-card"></i> <%= pm ? pm.name : 'Payment method' %></span>
                            <% } %>
                        </div>
                    </div>

                    <details class="mb-2">
                        <summary class="cursor-pointer text-sky-400 text-xs font-semibold uppercase tracking-wide">Edit Details</summary>
                        <form method="POST" action="/admin/users/<%= u.id %>/update" class="grid sm:grid-cols-3 gap-3 mt-3">
                            <input type="text" name="name" required class="input" value="<%= u.name %>" placeholder="Full name">
                            <input type="email" name="email" required class="input sm:col-span-2" value="<%= u.email %>" placeholder="Email address">
                            <button type="submit" class="btn-primary rounded-xl text-sm sm:col-span-3">Save Details</button>
                        </form>
                    </details>

                    <details class="mb-2">
                        <summary class="cursor-pointer text-sky-400 text-xs font-semibold uppercase tracking-wide">Assign / Manage Plan</summary>
                        <form method="POST" action="/admin/users/<%= u.id %>/subscription" class="grid sm:grid-cols-4 gap-3 mt-3">
                            <select name="plan_id" required class="input sm:col-span-2">
                                <option value="">Choose a plan…</option>
                                <% plans.forEach(function(p) { %>
                                    <option value="<%= p.id %>"><%= p.name %> (<%= p.service %>)</option>
                                <% }); %>
                            </select>
                            <select name="status" class="input">
                                <option value="active">Active</option>
                                <option value="suspended">Suspended</option>
                                <option value="expired">Expired</option>
                            </select>
                            <input type="date" name="expires_at" class="input" placeholder="Renewal date">
                            <select name="renewal_mode" class="input sm:col-span-2">
                                <option value="manual">Manual renewal (admin renews each time)</option>
                                <option value="auto">Auto-renew (rolls forward automatically each month)</option>
                                <option value="expired">Mark as expired now</option>
                            </select>
                            <button type="submit" class="btn-primary rounded-xl text-sm sm:col-span-2">Assign Plan</button>
                        </form>
                        <% if ((subsByUser[u.id] || []).length > 0) { %>
                            <div class="mt-3 space-y-1">
                                <% subsByUser[u.id].forEach(function(s) { %>
                                    <form method="POST" action="/admin/users/<%= u.id %>/subscription/<%= s.id %>/delete" class="flex items-center justify-between text-xs text-slate-500 bg-slate-900/40 rounded-lg px-3 py-2 gap-2">
                                        <span class="truncate">
                                            <%= s.plan_display_name || s.plan_name %> (<%= s.status %>)
                                            <% if (s.expires_at) { %> — <%= s.renewal_mode === 'auto' ? 'auto-renews' : 'renews' %> <%= formatUKDate(s.expires_at) %><% } %>
                                            <% if (s.renewal_mode) { %> <span class="text-slate-600">[<%= s.renewal_mode %>]</span><% } %>
                                        </span>
                                        <button class="text-red-400 hover:text-red-300 flex-shrink-0"><i class="fas fa-trash"></i></button>
                                    </form>
                                <% }); %>
                            </div>
                        <% } %>
                    </details>

                    <details class="mb-2">
                        <summary class="cursor-pointer text-sky-400 text-xs font-semibold uppercase tracking-wide">Payment Method</summary>
                        <form method="POST" action="/admin/users/<%= u.id %>/payment-method" class="flex flex-col sm:flex-row gap-3 mt-3">
                            <select name="payment_method_id" class="input">
                                <option value="">None</option>
                                <% paymentMethods.forEach(function(pm) { %>
                                    <option value="<%= pm.id %>" <%= u.payment_method_id === pm.id ? 'selected' : '' %>><%= pm.name %></option>
                                <% }); %>
                            </select>
                            <button type="submit" class="btn-primary py-3 rounded-xl text-sm whitespace-nowrap">Save</button>
                        </form>
                    </details>

                    <div class="flex flex-wrap gap-4 mt-4 text-xs">
                        <form method="POST" action="/admin/users/<%= u.id %>/reset-password" onsubmit="return confirm('Reset this user\'s password?');">
                            <button class="text-amber-400 hover:text-amber-300"><i class="fas fa-key mr-1"></i>Reset Password</button>
                        </form>
                        <form method="POST" action="/admin/users/<%= u.id %>/delete" onsubmit="return confirm('Delete this user permanently? This cannot be undone.');">
                            <button class="text-red-400 hover:text-red-300"><i class="fas fa-user-slash mr-1"></i>Delete User</button>
                        </form>
                    </div>
                </div>
            <% }); %>
            <% if (users.length === 0) { %>
                <p class="text-slate-500 text-sm">No clients yet — invite your first one above.</p>
            <% } %>
        </div>
    </main>
</body>
</html>
