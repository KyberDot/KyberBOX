<!DOCTYPE html>
<html lang="en">
<head>
    <% pageTitle = 'My Account | ' + siteName %>
    <%- include('partials/head') %>
</head>
<body class="antialiased overflow-x-hidden">
    <%- include('partials/nav') %>

    <main class="max-w-5xl mx-auto px-4 sm:px-6 py-8 sm:py-10 relative">
        <div class="hero-glow" style="top:0;"></div>

        <div class="relative z-10">
            <h1 class="text-2xl sm:text-3xl font-extrabold mb-1">Welcome back, <%= currentUser.name.split(' ')[0] %></h1>
            <p class="text-slate-400 mb-2 text-sm sm:text-base">Here's what's happening with your account.</p>
            <% if (paymentMethodName) { %>
                <p class="text-slate-500 text-xs mb-8 sm:mb-10"><i class="fas fa-credit-card mr-1.5"></i>Payment method on file: <span class="text-slate-300"><%= paymentMethodName %></span></p>
            <% } else { %>
                <div class="mb-8 sm:mb-10"></div>
            <% } %>

            <!-- Maintenance banners -->
            <% planViews.forEach(function(pv) { %>
                <% if (pv.plan.maintenance_mode) { %>
                    <div class="mb-6 px-4 sm:px-5 py-4 rounded-xl bg-amber-500/10 border border-amber-500/30 text-amber-400 text-sm">
                        <i class="fas fa-screwdriver-wrench mr-2"></i>
                        <strong><%= pv.plan.name %></strong> is currently running scheduled maintenance.
                        <% if (pv.plan.maintenance_message) { %>
                            <%= pv.plan.maintenance_message %>
                        <% } %>
                        <% if (pv.plan.maintenance_resume_at) { %>
                            We expect to resume by <strong><%= formatUK(pv.plan.maintenance_resume_at) %></strong>.
                        <% } %>
                    </div>
                <% } %>
            <% }); %>

            <% if (legacySubscriptions.length > 0) { %>
                <div class="mb-8 px-4 sm:px-5 py-4 rounded-xl bg-amber-500/10 border border-amber-500/30 text-amber-400 text-sm">
                    <i class="fas fa-triangle-exclamation mr-2"></i>Some of your subscriptions haven't been assigned to a plan yet — contact support if you don't see the features you expect below.
                </div>
            <% } %>

            <% if (planViews.length === 0 && legacySubscriptions.length === 0) { %>
                <div class="glass rounded-2xl p-6 text-slate-400 text-sm mb-10">
                    No subscriptions on file yet. Please contact support if this seems wrong.
                </div>
            <% } %>

            <!-- One card per active plan subscription -->
            <% planViews.forEach(function(pv) { %>
                <div class="glass rounded-3xl p-5 sm:p-8 mb-8">
                    <div class="flex flex-wrap items-start justify-between gap-3 mb-2">
                        <div>
                            <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-1"><%= pv.plan.service %></p>
                            <h2 class="text-lg sm:text-xl font-bold text-white"><%= pv.plan.name %></h2>
                            <% if (pv.plan.description) { %>
                                <p class="text-slate-400 text-sm mt-1"><%= pv.plan.description %></p>
                            <% } %>
                        </div>
                        <div class="text-right flex-shrink-0">
                            <span class="badge badge-<%= pv.subscription.status %>"><%= pv.subscription.status %></span>
                            <% if (pv.plan.price !== null && pv.plan.price !== undefined) { %>
                                <p class="text-white font-bold mt-2"><%= formatMoney(pv.plan.price, pv.plan.currency) %><span class="text-slate-500 text-xs font-normal">/mo</span></p>
                            <% } %>
                        </div>
                    </div>
                    <% if (pv.subscription.expires_at) { %>
                        <p class="text-slate-500 text-xs mb-5">Renews on <%= formatUKDate(pv.subscription.expires_at) %></p>
                    <% } %>

                    <!-- Features -->
                    <% if (pv.plan.features) { %>
                        <div class="mb-6">
                            <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-3">Included with this plan</p>
                            <ul class="grid sm:grid-cols-2 gap-2">
                                <% pv.plan.features.split('\n').filter(f => f.trim()).forEach(function(feature) { %>
                                    <li class="flex items-start gap-2 text-sm text-slate-300">
                                        <i class="fas fa-check text-emerald-400 mt-1 text-xs"></i>
                                        <span><%= feature.trim() %></span>
                                    </li>
                                <% }); %>
                            </ul>
                        </div>
                    <% } %>

                    <!-- Container health -->
                    <% if (pv.containers.length > 0) { %>
                        <div class="mb-6" data-plan-id="<%= pv.plan.id %>" data-health-container>
                            <p class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-3">Server Status</p>
                            <div class="grid sm:grid-cols-2 gap-2">
                                <% pv.containers.forEach(function(c) { %>
                                    <div class="flex items-center justify-between bg-slate-900/40 rounded-xl px-4 py-3" data-container-name="<%= c.container_name %>">
                                        <span class="text-sm text-slate-300"><%= c.label %></span>
                                        <span class="badge badge-suspended" data-status-pill><i class="fas fa-circle-notch fa-spin"></i> checking</span>
                                    </div>
                                <% }); %>
                            </div>
                        </div>
                    <% } %>

                    <!-- Actions -->
                    <% if (pv.actions.length > 0) { %>
                        <div class="flex flex-col sm:flex-row sm:flex-wrap gap-3">
                            <% pv.actions.forEach(function(action) { %>
                                <button
                                    class="btn-amber px-6 py-3 rounded-2xl text-sm w-full sm:w-auto"
                                    data-action-btn
                                    data-action-id="<%= action.id %>"
                                    data-action-label="<%= action.label %>"
                                    data-cooldown-hours="<%= action.cooldown_hours %>"
                                    <%= (action.nextAllowedAt || pv.plan.maintenance_mode) ? 'disabled' : '' %>
                                >
                                    <i class="fas <%= action.icon %> mr-2"></i>
                                    <%= pv.plan.maintenance_mode ? action.label + ' Unavailable' : (action.nextAllowedAt ? action.label + ' Unavailable' : action.label) %>
                                </button>
                            <% }); %>
                        </div>
                        <div class="mt-4 flex flex-wrap gap-4">
                            <% pv.actions.forEach(function(action) { %>
                                <% if (action.nextAllowedAt && !pv.plan.maintenance_mode) { %>
                                    <p class="text-slate-500 text-xs">"<%= action.label %>" available again after <span><%= formatUK(action.nextAllowedAt) %></span></p>
                                <% } %>
                            <% }); %>
                        </div>
                        <div id="actionResult-<%= pv.plan.id %>" class="mt-4 hidden text-sm rounded-xl p-4"></div>
                        <a href="#raise-ticket" onclick="document.getElementById('category').value='<%= pv.plan.service %>'"
                           class="btn-outline inline-block text-center px-6 py-3 rounded-2xl text-sm mt-4">
                            <i class="fas fa-life-ring mr-2"></i> Still having issues? Raise a ticket
                        </a>
                    <% } %>
                </div>
            <% }); %>

            <!-- Tickets -->
            <h2 id="tickets" class="text-sm uppercase tracking-widest text-slate-500 font-bold mb-4">Support Tickets</h2>
            <div class="glass rounded-3xl p-5 sm:p-8 mb-8">
                <% if (tickets.length === 0) { %>
                    <p class="text-slate-500 text-sm mb-2">No tickets yet.</p>
                <% } else { %>
                    <div class="space-y-3 mb-2">
                        <% tickets.forEach(function(t) { %>
                            <a href="/dashboard/tickets/<%= t.id %>" class="flex items-center justify-between gap-3 p-4 rounded-xl bg-slate-900/40 hover:bg-slate-900/70 transition">
                                <div class="min-w-0">
                                    <p class="font-semibold text-white text-sm truncate"><%= t.subject %></p>
                                    <p class="text-slate-500 text-xs"><%= t.category %> · opened <%= formatUK(t.created_at) %></p>
                                </div>
                                <span class="badge badge-<%= t.status %> flex-shrink-0"><%= t.status %></span>
                            </a>
                        <% }); %>
                    </div>
                <% } %>
            </div>

            <div id="raise-ticket" class="glass rounded-3xl p-5 sm:p-8 mb-16">
                <h3 class="text-lg font-bold text-white mb-4">Raise a New Ticket</h3>
                <form method="POST" action="/dashboard/tickets" class="space-y-4">
                    <input type="text" name="subject" required class="input" placeholder="Subject">
                    <select id="category" name="category" class="input">
                        <option value="general">General</option>
                        <option value="plex">Plex</option>
                        <option value="docker">Docker Hosting</option>
                        <option value="stream">Stream Addons</option>
                        <option value="indexers">Indexers</option>
                        <option value="hosting">Web Hosting</option>
                    </select>
                    <textarea name="message" required rows="4" class="input" placeholder="Describe the issue..."></textarea>
                    <button type="submit" class="btn-primary px-8 py-3 rounded-2xl text-sm w-full sm:w-auto">
                        <i class="fas fa-paper-plane mr-2"></i> Submit Ticket
                    </button>
                </form>
            </div>
        </div>
    </main>

    <!-- Confirmation Modal (shared by all action buttons) -->
    <div id="actionModal" class="fixed inset-0 bg-black/70 backdrop-blur-sm hidden items-center justify-center z-50 px-6">
        <div class="glass rounded-3xl p-8 max-w-sm w-full text-center">
            <div class="w-16 h-16 mx-auto rounded-full bg-amber-500/10 border border-amber-500/30 flex items-center justify-center mb-5">
                <i class="fas fa-triangle-exclamation text-amber-400 text-2xl"></i>
            </div>
            <h3 id="actionModalTitle" class="text-lg font-bold text-white mb-2">Run this action?</h3>
            <p id="actionModalBody" class="text-slate-400 text-sm mb-6"></p>
            <div class="flex gap-3">
                <button onclick="closeActionModal()" class="btn-outline flex-1 py-3 rounded-xl text-sm">Cancel</button>
                <button onclick="confirmAction()" class="btn-amber flex-1 py-3 rounded-xl text-sm">Yes, Continue</button>
            </div>
        </div>
    </div>

    <script>
        let pendingActionBtn = null;

        document.querySelectorAll('[data-action-btn]').forEach(function(btn) {
            btn.addEventListener('click', function() {
                if (btn.disabled) return;
                pendingActionBtn = btn;
                const label = btn.getAttribute('data-action-label');
                const hours = btn.getAttribute('data-cooldown-hours');
                document.getElementById('actionModalTitle').textContent = label + ' now?';
                document.getElementById('actionModalBody').textContent =
                    'This will run "' + label + '" on your server. You\'ll only be able to do this again in ' + hours + ' hour(s).';
                const modal = document.getElementById('actionModal');
                modal.classList.remove('hidden');
                modal.classList.add('flex');
            });
        });

        function closeActionModal() {
            const modal = document.getElementById('actionModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
            pendingActionBtn = null;
        }

        async function confirmAction() {
            const btn = pendingActionBtn;
            closeActionModal();
            if (!btn) return;

            const actionId = btn.getAttribute('data-action-id');
            const card = btn.closest('.glass');
            const resultBox = card ? card.querySelector('[id^="actionResult-"]') : null;

            btn.disabled = true;
            const originalHtml = btn.innerHTML;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin mr-2"></i> Working...';

            try {
                const res = await fetch('/dashboard/actions/' + actionId + '/run', { method: 'POST' });
                const data = await res.json();
                if (resultBox) {
                    resultBox.classList.remove('hidden');
                    resultBox.className = 'mt-4 text-sm rounded-xl p-4 ' + (data.ok
                        ? 'bg-emerald-500/10 border border-emerald-500/30 text-emerald-400'
                        : 'bg-red-500/10 border border-red-500/30 text-red-400');
                    resultBox.textContent = data.message;
                }
                if (data.ok) {
                    btn.innerHTML = '<i class="fas fa-check mr-2"></i> Done';
                } else {
                    btn.disabled = false;
                    btn.innerHTML = originalHtml;
                }
            } catch (e) {
                if (resultBox) {
                    resultBox.classList.remove('hidden');
                    resultBox.className = 'mt-4 text-sm rounded-xl p-4 bg-red-500/10 border border-red-500/30 text-red-400';
                    resultBox.textContent = 'Something went wrong sending that request.';
                }
                btn.disabled = false;
                btn.innerHTML = originalHtml;
            }
        }

        // Fetch live container health for each plan card without blocking page load
        document.querySelectorAll('[data-health-container]').forEach(async function(el) {
            const planId = el.getAttribute('data-plan-id');
            try {
                const res = await fetch('/dashboard/plans/' + planId + '/health');
                const data = await res.json();
                if (!data.ok) return;
                data.containers.forEach(function(c) {
                    const row = el.querySelector('[data-container-name="' + c.container_name + '"] [data-status-pill]');
                    if (!row) return;
                    const map = {
                        up: ['badge-active', 'fa-circle-check', 'Online'],
                        starting: ['badge-suspended', 'fa-circle-notch fa-spin', 'Starting'],
                        unhealthy: ['badge-expired', 'fa-triangle-exclamation', 'Unhealthy'],
                        down: ['badge-expired', 'fa-circle-xmark', 'Offline'],
                        unknown: ['badge-closed', 'fa-question', 'Unknown'],
                    };
                    const chosen = map[c.status] || map.unknown;
                    row.className = 'badge ' + chosen[0];
                    row.innerHTML = '<i class="fas ' + chosen[1] + '"></i> ' + chosen[2];
                });
            } catch (e) {
                // leave "checking" state as-is on failure
            }
        });
    </script>
</body>
</html>
