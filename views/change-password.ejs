<!DOCTYPE html>
<html lang="en">
<head>
    <% pageTitle = 'Set Your Password' %>
    <%- include('partials/head') %>
</head>
<body class="antialiased overflow-x-hidden flex flex-col min-h-screen">
    <%- include('partials/nav') %>

    <main class="flex-grow flex items-center justify-center px-6 py-12 relative">
        <div class="hero-glow"></div>
        <div class="max-w-md w-full relative z-10">
            <h1 class="text-2xl font-extrabold mb-2 text-center">Set a new password</h1>
            <p class="text-slate-400 text-sm text-center mb-8">For security, please choose a new password before continuing.</p>

            <div class="glass rounded-3xl p-8">
                <% if (typeof error !== 'undefined' && error) { %>
                    <div class="mb-5 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm">
                        <i class="fas fa-triangle-exclamation mr-2"></i><%= error %>
                    </div>
                <% } %>
                <form method="POST" action="/change-password" class="space-y-4">
                    <input type="password" name="current_password" required class="input" placeholder="Current / temporary password">
                    <input type="password" name="new_password" required class="input" placeholder="New password (min 8 characters)">
                    <input type="password" name="confirm_password" required class="input" placeholder="Confirm new password">
                    <button type="submit" class="w-full btn-primary py-4 rounded-2xl text-sm mt-2">Update Password</button>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
