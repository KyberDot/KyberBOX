<!DOCTYPE html>
<html lang="en">
<head>
    <% pageTitle = 'Reset Password | ' + siteName %>
    <%- include('partials/head') %>
</head>
<body class="antialiased overflow-x-hidden flex flex-col min-h-screen">
    <nav class="max-w-7xl mx-auto px-8 py-6 w-full">
        <img src="/img/KY.svg" alt="Logo" class="h-10 w-auto">
    </nav>

    <main class="flex-grow flex items-center justify-center px-6 py-12 relative">
        <div class="hero-glow"></div>
        <div class="max-w-md w-full relative z-10">

            <% if (typeof success !== 'undefined' && success) { %>
                <div class="glass rounded-3xl p-8 text-center">
                    <div class="w-14 h-14 mx-auto rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center mb-4">
                        <i class="fas fa-circle-check text-emerald-400 text-xl"></i>
                    </div>
                    <h1 class="text-xl font-bold text-white mb-2">Password updated</h1>
                    <p class="text-slate-400 text-sm mb-6">You can now sign in with your new password.</p>
                    <a href="/login" class="btn-primary px-6 py-3 rounded-xl text-sm inline-block">Go to Sign In</a>
                </div>
            <% } else if (!valid) { %>
                <div class="glass rounded-3xl p-8 text-center">
                    <div class="w-14 h-14 mx-auto rounded-full bg-red-500/10 border border-red-500/30 flex items-center justify-center mb-4">
                        <i class="fas fa-triangle-exclamation text-red-400 text-xl"></i>
                    </div>
                    <h1 class="text-xl font-bold text-white mb-2">Link invalid or expired</h1>
                    <p class="text-slate-400 text-sm mb-6">Reset links are only valid for 30 minutes and can only be used once.</p>
                    <a href="/forgot-password" class="btn-primary px-6 py-3 rounded-xl text-sm inline-block">Request a New Link</a>
                </div>
            <% } else { %>
                <h1 class="text-2xl font-extrabold mb-2 text-center">Choose a new password</h1>
                <p class="text-slate-400 text-sm text-center mb-8">Make it at least 8 characters.</p>
                <div class="glass rounded-3xl p-8">
                    <% if (error) { %>
                        <div class="mb-5 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/30 text-red-400 text-sm">
                            <i class="fas fa-triangle-exclamation mr-2"></i><%= error %>
                        </div>
                    <% } %>
                    <form method="POST" action="/reset-password/<%= token %>" class="space-y-4">
                        <input type="password" name="new_password" required class="input" placeholder="New password">
                        <input type="password" name="confirm_password" required class="input" placeholder="Confirm new password">
                        <button type="submit" class="w-full btn-primary py-4 rounded-2xl text-sm">Update Password</button>
                    </form>
                </div>
            <% } %>
        </div>
    </main>
</body>
</html>
