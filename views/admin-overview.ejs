<!DOCTYPE html>
<html lang="en">
<head>
    <% pageTitle = 'Admin Overview' %>
    <%- include('partials/head') %>
</head>
<body class="antialiased overflow-x-hidden">
    <%- include('partials/nav') %>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-10">
        <h1 class="text-2xl sm:text-3xl font-extrabold mb-8">Admin Overview</h1>

        <% if (!mailConfigured) { %>
            <div class="mb-8 px-4 sm:px-5 py-4 rounded-xl bg-amber-500/10 border border-amber-500/30 text-amber-400 text-sm flex items-center justify-between flex-wrap gap-3">
                <span><i class="fas fa-envelope-circle-check mr-2"></i>Email isn't configured yet — invites, password resets, and ticket notifications won't be sent.</span>
                <a href="/admin/settings" class="btn-amber px-4 py-2 rounded-lg text-xs whitespace-nowrap">Set Up Mail</a>
            </div>
        <% } %>

        <div class="grid sm:grid-cols-2 md:grid-cols-4 gap-4 sm:gap-5 mb-10 sm:mb-12">
            <div class="glass rounded-2xl p-5 sm:p-6">
                <p class="text-slate-500 text-xs uppercase tracking-widest font-semibold mb-2">Subscribers</p>
                <p class="text-2xl sm:text-3xl font-extrabold text-white"><%= userCount %></p>
            </div>
            <div class="glass rounded-2xl p-5 sm:p-6">
                <p class="text-slate-500 text-xs uppercase tracking-widest font-semibold mb-2">Plans</p>
                <p class="text-2xl sm:text-3xl font-extrabold text-white"><%= planCount %></p>
            </div>
            <div class="glass rounded-2xl p-5 sm:p-6">
                <p class="text-slate-500 text-xs uppercase tracking-widest font-semibold mb-2">Active Subscriptions</p>
                <p class="text-2xl sm:text-3xl font-extrabold text-sky-400"><%= activeSubs %></p>
            </div>
            <div class="glass rounded-2xl p-5 sm:p-6">
                <p class="text-slate-500 text-xs uppercase tracking-widest font-semibold mb-2">Open Tickets</p>
                <p class="text-2xl sm:text-3xl font-extrabold text-amber-400"><%= openTickets %></p>
            </div>
        </div>

        <div class="flex flex-wrap gap-3 sm:gap-4 mb-10 sm:mb-12">
            <a href="/admin/users" class="btn-primary px-5 sm:px-6 py-3 rounded-2xl text-sm"><i class="fas fa-users mr-2"></i>Manage Users</a>
            <a href="/admin/plans" class="btn-outline px-5 sm:px-6 py-3 rounded-2xl text-sm"><i class="fas fa-layer-group mr-2"></i>Manage Plans</a>
            <a href="/admin/tickets" class="btn-outline px-5 sm:px-6 py-3 rounded-2xl text-sm"><i class="fas fa-life-ring mr-2"></i>View Tickets</a>
        </div>

        <h2 class="text-sm uppercase tracking-widest text-slate-500 font-bold mb-4">Recent Action Requests</h2>
        <div class="glass rounded-2xl overflow-x-auto">
            <% if (recentActions.length === 0) { %>
                <p class="text-slate-500 text-sm p-6">No action requests yet.</p>
            <% } else { %>
                <table class="kb-table min-w-[560px]">
                    <thead><tr><th>User</th><th>Action</th><th>Time</th><th>Result</th></tr></thead>
                    <tbody>
                        <% recentActions.forEach(function(r) { %>
                            <tr>
                                <td><%= r.name %><br><span class="text-slate-500 text-xs"><%= r.email %></span></td>
                                <td class="text-slate-300"><%= r.action_label %></td>
                                <td class="text-slate-400"><%= r.requested_at %></td>
                                <td>
                                    <% if (r.success) { %>
                                        <span class="badge badge-active">Success</span>
                                    <% } else { %>
                                        <span class="badge badge-expired">Failed</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }); %>
                    </tbody>
                </table>
            <% } %>
        </div>
    </main>
</body>
</html>
