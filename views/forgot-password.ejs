<!DOCTYPE html>
<html lang="en">
<head>
    <% pageTitle = 'Forgot Password | ' + siteName %>
    <%- include('partials/head') %>
</head>
<body class="antialiased overflow-x-hidden flex flex-col min-h-screen">
    <nav class="max-w-7xl mx-auto px-8 py-6 w-full">
        <img src="/img/KY.svg" alt="Logo" class="h-10 w-auto">
    </nav>

    <main class="flex-grow flex items-center justify-center px-6 py-12 relative">
        <div class="hero-glow"></div>
        <div class="max-w-md w-full relative z-10">
            <h1 class="text-3xl font-extrabold mb-2 text-center">Reset your <span class="gradient-text">password</span></h1>
            <p class="text-slate-400 text-sm text-center mb-8">Enter your account email and we'll send you a reset link.</p>

            <div class="glass rounded-3xl p-8">
                <% if (sent) { %>
                    <div class="text-center">
                        <div class="w-14 h-14 mx-auto rounded-full bg-emerald-500/10 border border-emerald-500/30 flex items-center justify-center mb-4">
                            <i class="fas fa-envelope-circle-check text-emerald-400 text-xl"></i>
                        </div>
                        <p class="text-slate-300 text-sm">If an account exists with that email, a reset link is on its way. Check your inbox (and spam folder).</p>
                    </div>
                <% } else { %>
                    <form method="POST" action="/forgot-password" class="space-y-4">
                        <input type="email" name="email" required class="input" placeholder="you@example.com">
                        <button type="submit" class="w-full btn-primary py-4 rounded-2xl text-sm">
                            <i class="fas fa-paper-plane mr-2"></i> Send Reset Link
                        </button>
                    </form>
                <% } %>
            </div>

            <p class="text-center text-slate-500 text-sm mt-8">
                <a href="/login" class="text-sky-400 hover:text-sky-300"><i class="fas fa-arrow-left mr-1"></i> Back to sign in</a>
            </p>
        </div>
    </main>
</body>
</html>
