<!DOCTYPE html>
<html lang="en">
<head>
    <% pageTitle = 'Plans' %>
    <%- include('partials/head') %>
</head>
<body class="antialiased overflow-x-hidden">
    <%- include('partials/nav') %>

    <main class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-10 pb-24">
        <h1 class="text-2xl sm:text-3xl font-extrabold mb-2">Plans</h1>
        <p class="text-slate-400 text-sm mb-8">Each plan controls what subscribers on it see when they log in: its feature list, its server access, its action buttons (like a Plex restart), and which containers' health is shown.</p>

        <!-- Create plan trigger -->
        <div class="flex justify-end mb-8">
            <button type="button" onclick="openModal('createPlanModal')" class="btn-primary px-6 py-3 rounded-xl text-sm">
                <i class="fas fa-plus mr-2"></i>Create a New Plan
            </button>
        </div>

        <!-- Plans list -->
        <div class="space-y-6">
            <% plans.forEach(function(plan) { %>
                <div class="glass rounded-2xl p-5 sm:p-6 <%= newPlanId === plan.id ? 'border border-emerald-500/40' : '' %>">
                    <div class="flex flex-wrap items-center justify-between gap-3 mb-4">
                        <div>
                            <p class="font-bold text-white text-lg"><%= plan.name %></p>
                            <div class="flex flex-wrap items-center gap-2 mt-1">
                                <span class="badge badge-answered"><%= plan.service %></span>
                                <% if (plan.price !== null && plan.price !== undefined) { %>
                                    <span class="badge badge-active"><%= formatMoney(plan.price, plan.currency) %>/mo</span>
                                <% } %>
                                <% if (plan.maintenance_mode) { %>
                                    <span class="badge badge-suspended"><i class="fas fa-triangle-exclamation"></i> Maintenance Mode</span>
                                <% } %>
                            </div>
                        </div>
                        <div class="flex flex-wrap gap-2">
                            <% if (sshByPlan[plan.id]) { %>
                                <span class="badge badge-active"><i class="fas fa-terminal"></i> SSH configured</span>
                            <% } else { %>
                                <span class="badge badge-suspended"><i class="fas fa-triangle-exclamation"></i> No SSH</span>
                            <% } %>
                            <span class="badge badge-answered"><i class="fas fa-bolt"></i> <%= (actionsByPlan[plan.id] || []).length %> action(s)</span>
                            <span class="badge badge-answered"><i class="fas fa-heart-pulse"></i> <%= (containersByPlan[plan.id] || []).length %> container(s)</span>
                        </div>
                    </div>

                    <details class="mb-3" data-ajax-key="plan-<%= plan.id %>-details">
                        <summary class="cursor-pointer text-sky-400 text-xs font-semibold uppercase tracking-wide">Plan Details &amp; Features</summary>
                        <form method="POST" action="/admin/plans/<%= plan.id %>/update" data-ajax-form class="grid sm:grid-cols-2 gap-3 mt-3">
                            <input type="text" name="name" required class="input" value="<%= plan.name %>">
                            <select name="service" class="input">
                                <option value="docker" <%= plan.service === 'docker' ? 'selected' : '' %>>Docker Hosting</option>
                                <option value="plex" <%= plan.service === 'plex' ? 'selected' : '' %>>Plex Servers</option>
                                <option value="stream" <%= plan.service === 'stream' ? 'selected' : '' %>>Stream Addons</option>
                                <option value="indexers" <%= plan.service === 'indexers' ? 'selected' : '' %>>Indexers</option>
                                <option value="hosting" <%= plan.service === 'hosting' ? 'selected' : '' %>>Web Hosting</option>
                                <option value="multiple" <%= plan.service === 'multiple' ? 'selected' : '' %>>Multiple Services</option>
                            </select>
                            <input type="text" name="description" class="input sm:col-span-2" value="<%= plan.description || '' %>" placeholder="Short description">
                            <input type="number" step="0.01" min="0" name="price" class="input" value="<%= plan.price !== null && plan.price !== undefined ? plan.price : '' %>" placeholder="Price (optional)">
                            <select name="currency" class="input">
                                <option value="GBP" <%= plan.currency === 'GBP' ? 'selected' : '' %>>GBP (£)</option>
                                <option value="USD" <%= plan.currency === 'USD' ? 'selected' : '' %>>USD ($)</option>
                                <option value="CAD" <%= plan.currency === 'CAD' ? 'selected' : '' %>>CAD ($)</option>
                            </select>
                            <textarea name="features" rows="4" class="input sm:col-span-2" placeholder="One feature per line"><%= plan.features || '' %></textarea>
                            <button type="submit" class="btn-primary py-3 rounded-xl text-sm sm:col-span-2">Save Details</button>
                        </form>
                    </details>

                    <details class="mb-3" data-ajax-key="plan-<%= plan.id %>-maintenance">
                        <summary class="cursor-pointer text-amber-400 text-xs font-semibold uppercase tracking-wide">Maintenance Mode <% if (plan.maintenance_mode) { %>(currently ON)<% } %></summary>
                        <form method="POST" action="/admin/plans/<%= plan.id %>/maintenance" data-ajax-form class="grid sm:grid-cols-2 gap-3 mt-3">
                            <label class="flex items-center gap-2 text-sm text-slate-300 sm:col-span-2">
                                <input type="checkbox" name="maintenance_mode" value="on" <%= plan.maintenance_mode ? 'checked' : '' %>>
                                Show a maintenance banner to subscribers on this plan
                            </label>
                            <div>
                                <label class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-1.5 block">Expected resume time (UK time)</label>
                                <input type="datetime-local" name="maintenance_resume_at" class="input" value="<%= plan.maintenance_resume_at ? utcToLondonInputValue(plan.maintenance_resume_at) : '' %>">
                            </div>
                            <div>
                                <label class="text-xs uppercase tracking-widest text-slate-500 font-semibold mb-1.5 block">Custom message (optional)</label>
                                <input type="text" name="maintenance_message" class="input" value="<%= plan.maintenance_message || '' %>" placeholder="Default: scheduled maintenance notice">
                            </div>
                            <button type="submit" class="btn-amber py-3 rounded-xl text-sm sm:col-span-2">
                                <i class="fas fa-triangle-exclamation mr-2"></i>Save Maintenance Settings
                            </button>
                        </form>
                    </details>

                    <details class="mb-3" data-ajax-key="plan-<%= plan.id %>-ssh">
                        <summary class="cursor-pointer text-sky-400 text-xs font-semibold uppercase tracking-wide">Server / SSH Access (shared by everyone on this plan)</summary>
                        <form method="POST" action="/admin/plans/<%= plan.id %>/ssh" data-ajax-form class="grid sm:grid-cols-3 gap-3 mt-3">
                            <input type="text" name="host" required class="input" placeholder="Host / IP" value="<%= sshByPlan[plan.id] ? sshByPlan[plan.id].host : '' %>">
                            <input type="number" name="port" class="input" placeholder="Port (22)" value="<%= sshByPlan[plan.id] ? sshByPlan[plan.id].port : 22 %>">
                            <input type="text" name="username" required class="input" placeholder="SSH username" value="<%= sshByPlan[plan.id] ? sshByPlan[plan.id].username : '' %>">
                            <select name="auth_type" class="input sm:col-span-3">
                                <option value="password" <%= sshByPlan[plan.id] && sshByPlan[plan.id].auth_type === 'password' ? 'selected' : '' %>>Password</option>
                                <option value="key" <%= sshByPlan[plan.id] && sshByPlan[plan.id].auth_type === 'key' ? 'selected' : '' %>>Private Key</option>
                            </select>
                            <textarea name="secret" rows="2" class="input sm:col-span-3" placeholder="Password or private key (leave blank to keep current)"></textarea>
                            <button type="submit" class="btn-primary py-3 rounded-xl text-sm sm:col-span-3">
                                <i class="fas fa-lock mr-2"></i>Save (encrypted at rest)
                            </button>
                        </form>
                    </details>

                    <details class="mb-3" data-ajax-key="plan-<%= plan.id %>-actions">
                        <summary class="cursor-pointer text-sky-400 text-xs font-semibold uppercase tracking-wide">Action Buttons (e.g. Restart Plex)</summary>
                        <div class="mt-3 space-y-2 mb-3">
                            <% (actionsByPlan[plan.id] || []).forEach(function(action) { %>
                                <form method="POST" action="/admin/plans/<%= plan.id %>/actions/<%= action.id %>/delete" data-ajax-form class="flex items-center justify-between text-xs text-slate-400 bg-slate-900/40 rounded-lg px-3 py-2 gap-2">
                                    <span class="truncate"><i class="fas <%= action.icon %> mr-2 text-sky-400"></i><strong class="text-white"><%= action.label %></strong> — <span class="font-mono"><%= action.command %></span> (every <%= action.cooldown_hours %>h)</span>
                                    <button type="submit" class="text-red-400 hover:text-red-300 flex-shrink-0"><i class="fas fa-trash"></i></button>
                                </form>
                            <% }); %>
                        </div>
                        <form method="POST" action="/admin/plans/<%= plan.id %>/actions" data-ajax-form class="grid sm:grid-cols-4 gap-3">
                            <input type="text" name="label" required class="input" placeholder="Button label (e.g. Restart Plex)">
                            <input type="text" name="command" required class="input sm:col-span-2" placeholder="Command (e.g. docker compose restart plex)">
                            <input type="number" name="cooldown_hours" class="input" placeholder="Cooldown hrs (6)" value="6">
                            <input type="text" name="icon" class="input sm:col-span-3" placeholder="Font Awesome icon class (default: fa-rotate)">
                            <button type="submit" class="btn-primary py-3 rounded-xl text-sm">Add Action</button>
                        </form>
                    </details>

                    <details data-ajax-key="plan-<%= plan.id %>-containers">
                        <summary class="cursor-pointer text-sky-400 text-xs font-semibold uppercase tracking-wide">Container Health (shown to subscribers)</summary>
                        <div class="mt-3 space-y-2 mb-3">
                            <% (containersByPlan[plan.id] || []).forEach(function(c) { %>
                                <form method="POST" action="/admin/plans/<%= plan.id %>/containers/<%= c.id %>/delete" data-ajax-form class="flex items-center justify-between text-xs text-slate-400 bg-slate-900/40 rounded-lg px-3 py-2 gap-2">
                                    <span><strong class="text-white"><%= c.label %></strong> — container: <span class="font-mono"><%= c.container_name %></span></span>
                                    <button type="submit" class="text-red-400 hover:text-red-300"><i class="fas fa-trash"></i></button>
                                </form>
                            <% }); %>
                        </div>
                        <form method="POST" action="/admin/plans/<%= plan.id %>/containers" data-ajax-form class="grid sm:grid-cols-3 gap-3">
                            <input type="text" name="label" required class="input" placeholder="Display label (e.g. Plex Server)">
                            <input type="text" name="container_name" required class="input" placeholder="Exact container name (e.g. plex)">
                            <button type="submit" class="btn-primary py-3 rounded-xl text-sm">Add Container</button>
                        </form>
                    </details>

                    <form method="POST" action="/admin/plans/<%= plan.id %>/delete" data-ajax-form data-confirm="Delete this plan? Subscribers on it will lose access to its features/actions until reassigned." class="mt-4">
                        <button type="submit" class="text-red-400 hover:text-red-300 text-xs"><i class="fas fa-trash mr-1"></i>Delete Plan</button>
                    </form>
                </div>
            <% }); %>
            <% if (plans.length === 0) { %>
                <p class="text-slate-500 text-sm">No plans yet — create one above to start assigning subscribers.</p>
            <% } %>
        </div>

        <!-- Create Plan Modal -->
        <div id="createPlanModal" class="fixed inset-0 bg-black/70 backdrop-blur-sm hidden items-center justify-center z-50 px-4 py-8 overflow-y-auto">
            <div class="glass rounded-3xl p-6 sm:p-8 max-w-lg w-full my-auto">
                <div class="flex items-center justify-between mb-5">
                    <h3 class="text-lg font-bold text-white"><i class="fas fa-layer-group mr-2 text-sky-400"></i>Create a New Plan</h3>
                    <button type="button" onclick="closeModal('createPlanModal')" class="text-slate-400 hover:text-white w-8 h-8 flex items-center justify-center rounded-lg hover:bg-white/5">
                        <i class="fas fa-xmark"></i>
                    </button>
                </div>
                <form method="POST" action="/admin/plans" data-ajax-form class="grid sm:grid-cols-2 gap-4">
                    <input type="text" name="name" required class="input sm:col-span-2" placeholder="Plan name (e.g. Plex Premium)">
                    <select name="service" class="input sm:col-span-2">
                        <option value="docker">Docker Hosting</option>
                        <option value="plex">Plex Servers</option>
                        <option value="stream">Stream Addons</option>
                        <option value="indexers">Indexers</option>
                        <option value="hosting">Web Hosting</option>
                        <option value="multiple">Multiple Services</option>
                    </select>
                    <input type="text" name="description" class="input sm:col-span-2" placeholder="Short description (optional)">
                    <input type="number" step="0.01" min="0" name="price" class="input" placeholder="Price (e.g. 9.99, optional)">
                    <select name="currency" class="input">
                        <option value="GBP">GBP (£)</option>
                        <option value="USD">USD ($)</option>
                        <option value="CAD">CAD ($)</option>
                    </select>
                    <textarea name="features" rows="3" class="input sm:col-span-2" placeholder="One feature per line, e.g.&#10;4K Transcoding&#10;5 simultaneous streams&#10;Priority support"></textarea>
                    <button type="submit" class="btn-primary py-3 rounded-xl text-sm sm:col-span-2 mt-2">
                        <i class="fas fa-plus mr-2"></i>Create Plan
                    </button>
                </form>
            </div>
        </div>
    </main>
</body>
</html>
